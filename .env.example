CLASSIFIER_CACHE_ENABLED=true
CLASSIFIER_CACHE_TTL_SEC=21600
CLASSIFIER_FALLBACK_NEUTRAL=true
CLASSIFIER_MODE=heuristic
CLASSIFIER_MODEL_NAME=monologg/bert-base-cased-goemotions-original
CLASSIFIER_DEVICE=cpu
CLASSIFIER_TOP_K=5
PYTHON_ML_INSTALL_EXTRAS=
LLM_PROVIDER=mock
LLM_BASE_URL=http://127.0.0.1:8000/v1
LLM_API_KEY=
LLM_MODEL=Qwen/Qwen3.5-27B
LLM_SYSTEM_PROMPT=You are a concise and emotionally coherent assistant. Reply briefly, helpfully, and stay aligned with the provided emotional context.
LLM_MAX_TOKENS=256
LLM_TEMPERATURE=0.2
LLM_TOP_P=0.8
LLM_TOP_K=20
LLM_PRESENCE_PENALTY=0.0
LLM_ENABLE_THINKING=false
